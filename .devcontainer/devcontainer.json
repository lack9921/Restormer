{
    "name": "Restormer CVPR2022 - Blackwell",
    "runArgs": [
        "--gpus",
        "all",
        "--shm-size",
        "16gb",
        "--env",
        "CUDA_VISIBLE_DEVICES=0"
    ],
    "mounts": [
        "source=D:\\dataset,target=/datasets_host,type=bind,consistency=cached"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance"
            ]
        }
    },
    "workspaceFolder": "/workspace",
    "remoteUser": "root",
    "shutdownAction": "none",
    "postCreateCommand": "cd /workspace && python setup.py develop --no_cuda_ext && echo 'Restormer ready!'",
    "image": "restormer:latest"
}